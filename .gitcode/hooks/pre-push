#!/usr/bin/env bash

# AgentOS 推送前钩子
# 在推送前运行完整测试套件和质量检查

set -e

echo "🚀 运行推送前检查..."

# 获取当前分支
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD)

# 不允许直接推送到 main/master 分支
PROTECTED_BRANCHES="main master release/*"

for branch in $PROTECTED_BRANCHES; do
    if [[ "$CURRENT_BRANCH" == $branch ]]; then
        echo "❌ 不能直接推送到受保护的分支: $branch"
        echo "   请创建 PR 进行代码审查"
        exit 1
    fi
done

# 检查是否有未提交的更改
if ! git diff-index --quiet HEAD --; then
    echo "⚠️  存在未提交的更改"
    echo "   请先提交所有更改再推送"
    read -p "继续推送？(y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# 检查分支名称规范
BRANCH_PATTERN="^(feature|bugfix|hotfix|release|docs|test|refactor)/[a-z0-9-]+$"
if ! echo "$CURRENT_BRANCH" | grep -qE "$BRANCH_PATTERN"; then
    if [[ "$CURRENT_BRANCH" != "develop" && "$CURRENT_BRANCH" != "main" && "$CURRENT_BRANCH" != "master" ]]; then
        echo "⚠️  分支名称不符合规范"
        echo "   当前分支: $CURRENT_BRANCH"
        echo "   推荐格式: feature/my-feature, bugfix/issue-123, etc."
        read -p "继续推送？(y/N): " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
fi

# 运行快速构建检查（如果存在构建脚本）
ROOT_DIR=$(git rev-parse --show-toplevel)

echo "🔧 检查项目构建..."

# 检查 daemon 模块
if [ -f "$ROOT_DIR/daemon/CMakeLists.txt" ]; then
    BUILD_DIR="$ROOT_DIR/build-daemon"
    if [ -d "$BUILD_DIR" ]; then
        cd "$BUILD_DIR"
        echo "📦 构建 daemon 模块..."
        if command -v cmake &> /dev/null; then
            cmake --build . --config Release --parallel 2>&1 | tail -20
            if [ $? -ne 0 ]; then
                echo "❌ 构建失败，请修复后再推送"
                cd "$ROOT_DIR"
                exit 1
            fi
            echo "✅ Daemon 构建成功"
        fi
        cd "$ROOT_DIR"
    fi
fi

# 检查 atoms 模块
if [ -f "$ROOT_DIR/atoms/CMakeLists.txt" ]; then
    ATOMS_BUILD="$ROOT_DIR/build-atoms"
    if [ -d "$ATOMS_BUILD" ]; then
        cd "$ATOMS_BUILD"
        echo "📦 构建 atoms 模块..."
        if command -v cmake &> /dev/null; then
            cmake --build . --config Release --parallel 2>&1 | tail -20
            if [ $? -ne 0 ]; then
                echo "❌ 构建失败，请修复后再推送"
                cd "$ROOT_DIR"
                exit 1
            fi
            echo "✅ Atoms 构建成功"
        fi
        cd "$ROOT_DIR"
    fi
fi

# 运行单元测试
echo "🧪 运行单元测试..."
TEST_FAILED=0

for test_dir in build-daemon build-atoms; do
    if [ -d "$ROOT_DIR/$test_dir" ]; then
        cd "$ROOT_DIR/$test_dir"
        if command -v ctest &> /dev/null; then
            ctest --output-on-failure -L unit --timeout 60 2>&1 | tail -30
            if [ $? -ne 0 ]; then
                TEST_FAILED=1
                echo "❌ 单元测试失败"
            else
                echo "✅ 单元测试通过 ($test_dir)"
            fi
        fi
        cd "$ROOT_DIR"
    fi
done

if [ $TEST_FAILED -ne 0 ]; then
    echo "❌ 存在失败的测试，请修复后再推送"
    exit 1
fi

# 显示推送摘要
echo ""
echo "📊 推送摘要:"
echo "   分支: $CURRENT_BRANCH"
echo "   远程: $(git remote get-url origin 2>/dev/null || echo 'N/A')"
echo "   提交数: $(git rev-list --count HEAD..$(git remote get-url origin 2>/dev/null | sed 's|.*/||')/$CURRENT_BRANCH 2>/dev/null || echo 'N/A')"

echo ""
echo "🎉 推送前检查全部通过！"
exit 0
