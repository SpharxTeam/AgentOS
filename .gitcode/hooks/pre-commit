#!/usr/bin/env bash

# AgentOS 预提交钩子
# 在提交前运行代码格式检查和测试

set -e

echo "🔍 运行预提交检查..."

# 获取暂存的文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|h|cpp|hpp|py|js|ts|rs|go)$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo "📭 没有需要检查的源代码文件"
    exit 0
fi

# 检查文件数量
FILE_COUNT=$(echo "$STAGED_FILES" | wc -l)
echo "📄 检查 $FILE_COUNT 个文件..."

# 1. 检查 C/C++ 文件格式
C_FILES=$(echo "$STAGED_FILES" | grep -E '\.(c|h|cpp|hpp)$' || true)
if [ -n "$C_FILES" ]; then
    echo "📝 检查 C/C++ 文件格式..."
    
    # 检查是否有 clang-format
    if command -v clang-format &> /dev/null; then
        for file in $C_FILES; do
            if [ -f "$file" ]; then
                # 检查格式是否一致
                if ! clang-format --dry-run --Werror "$file" &> /dev/null; then
                    echo "❌ $file 格式不符合规范"
                    echo "   运行: clang-format -i $file"
                    exit 1
                fi
            fi
        done
        echo "✅ C/C++ 文件格式检查通过"
    else
        echo "⚠️  未找到 clang-format，跳过格式检查"
    fi
fi

# 2. 检查 Python 文件
PY_FILES=$(echo "$STAGED_FILES" | grep -E '\.py$' || true)
if [ -n "$PY_FILES" ]; then
    echo "🐍 检查 Python 文件..."
    
    # 检查是否有 black
    if command -v black &> /dev/null; then
        for file in $PY_FILES; do
            if [ -f "$file" ]; then
                if ! black --check --quiet "$file" &> /dev/null; then
                    echo "❌ $file 格式不符合规范"
                    echo "   运行: black $file"
                    exit 1
                fi
            fi
        done
        echo "✅ Python 文件格式检查通过"
    else
        echo "⚠️  未找到 black，跳过格式检查"
    fi
fi

# 3. 运行相关测试（如果有）
echo "🧪 运行相关测试..."
ROOT_DIR=$(git rev-parse --show-toplevel)

# 检查是否在 daemon 目录有修改
if echo "$STAGED_FILES" | grep -q "^daemon/"; then
    echo "🔧 检测到 daemon 模块修改，运行相关测试..."
    
    if [ -f "$ROOT_DIR/daemon/CMakeLists.txt" ]; then
        BUILD_DIR="$ROOT_DIR/build-daemon"
        if [ -d "$BUILD_DIR" ]; then
            cd "$BUILD_DIR"
            # 运行单元测试
            if command -v ctest &> /dev/null; then
                if ! ctest --output-on-failure -L "unit" 2>/dev/null; then
                    echo "❌ 单元测试失败"
                    exit 1
                fi
            fi
            cd "$ROOT_DIR"
        fi
    fi
fi

# 4. 检查 TODO/FIXME 注释
echo "📋 检查临时注释..."
if echo "$STAGED_FILES" | xargs grep -n "TODO\|FIXME" 2>/dev/null | grep -v ".gitcode/" | head -5; then
    echo "⚠️  代码中存在 TODO/FIXME 注释，请确认是否应该提交"
    read -p "继续提交？(y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

# 5. 检查调试代码
echo "🐛 检查调试代码..."
if echo "$STAGED_FILES" | xargs grep -n "printf(\|console\.log\|print(" 2>/dev/null | grep -v "test" | head -5; then
    echo "⚠️  代码中可能存在调试输出，请确认是否应该提交"
    read -p "继续提交？(y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

echo "🎉 预提交检查通过！"
exit 0