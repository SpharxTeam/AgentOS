#!/usr/bin/env bash

# AgentOS 提交消息格式检查钩子
# 强制使用规范的提交消息格式

# 支持的提交类型
TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# 获取提交消息
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 检查是否为空
if [ -z "$COMMIT_MSG" ]; then
    echo "❌ 提交消息不能为空"
    exit 1
fi

# 检查消息长度
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n1)
if [ ${#FIRST_LINE} -gt 72 ]; then
    echo "❌ 提交消息第一行超过 72 个字符"
    echo "   当前: ${#FIRST_LINE} 字符"
    exit 1
fi

# 检查是否符合 Conventional Commits 格式
# 格式: type(scope): description
if ! echo "$FIRST_LINE" | grep -qE "^($TYPES)(\(.+\))?: .+$"; then
    echo "❌ 提交消息格式不符合规范"
    echo ""
    echo "   正确格式: <type>(<scope>): <description>"
    echo ""
    echo "   可用的类型:"
    echo "     feat     新功能"
    echo "     fix      Bug 修复"
    echo "     docs     文档变更"
    echo "     style    代码格式（不影响功能）"
    echo "     refactor 代码重构"
    echo "     perf     性能优化"
    echo "     test     测试相关"
    echo "     build    构建系统或依赖变更"
    echo "     ci       CI/CD 配置变更"
    echo "     chore    杂项（不影响源码和测试）"
    echo "     revert   回滚提交"
    echo ""
    echo "   示例:"
    echo "     feat(gateway): add JWT authentication support"
    echo "     fix(daemon): resolve memory leak in event loop"
    echo "     docs(readme): update installation instructions"
    echo ""
    echo "   如果这是紧急修复，请使用 --no-verify 绕过检查"
    exit 1
fi

# 检查是否有空行分隔标题和正文
LINE_COUNT=$(echo "$COMMIT_MSG" | wc -l)
if [ $LINE_COUNT -gt 1 ]; then
    SECOND_LINE=$(echo "$COMMIT_MSG" | sed -n '2p')
    if [ -n "$SECOND_LINE" ]; then
        echo "⚠️  建议在标题和正文之间添加空行"
        # 这只是警告，不阻止提交
    fi
fi

# 检查是否包含 Issue 引用
if ! echo "$COMMIT_MSG" | grep -qE "(Closes|Fixes|Resolves) #[0-9]+"; then
    if ! echo "$COMMIT_MSG" | grep -qE "#[0-9]+"; then
        # 只在非 trivial 变更时提示
        TYPE=$(echo "$FIRST_LINE" | cut -d'(' -f1)
        if [[ "$TYPE" == "feat" || "$TYPE" == "fix" ]]; then
            echo "💡 建议关联相关 Issue (例如: Closes #123)"
            # 这只是建议，不阻止提交
        fi
    fi
fi

# 检查是否包含 WIP 标记
if echo "$FIRST_LINE" | grep -qi "wip\|work in progress\|todo"; then
    echo "⚠️  检测到 WIP/TODO 标记，确认要提交吗？"
    read -p "继续提交？(y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        exit 1
    fi
fi

echo "✅ 提交消息格式检查通过"
exit 0
