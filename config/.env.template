# =============================================================================
# AgentOS 环境变量配置模板
# 版本: v1.0.0
# 最后更新: 2026-03-23
# =============================================================================

# -----------------------------------------------------------------------------
# 核心路径配置（跨平台支持）
# -----------------------------------------------------------------------------

# AgentOS 根目录（自动检测，通常无需手动设置）
# AGENTOS_ROOT=/path/to/AgentOS

# 数据目录
AGENTOS_DATA_DIR=${AGENTOS_ROOT}/partdata

# 日志目录
AGENTOS_LOG_DIR=${AGENTOS_DATA_DIR}/logs

# 临时目录
AGENTOS_TEMP_DIR=${AGENTOS_DATA_DIR}/temp

# 缓存目录
AGENTOS_CACHE_DIR=${AGENTOS_DATA_DIR}/cache

# 配置目录
AGENTOS_CONFIG_DIR=${AGENTOS_ROOT}/config

# -----------------------------------------------------------------------------
# 系统路径（跨平台兼容）
# -----------------------------------------------------------------------------

# Unix/Linux/macOS 示例:
# SYSTEM_BIN_DIR=/usr/bin
# SYSTEM_TEMP_DIR=/tmp

# Windows 示例:
# SYSTEM_BIN_DIR=C:\Windows\System32
# SYSTEM_TEMP_DIR=C:\Windows\Temp

# 通用临时目录（优先使用）
SYSTEM_TEMP_DIR=${AGENTOS_TEMP_DIR}

# -----------------------------------------------------------------------------
# LLM API 密钥配置
# -----------------------------------------------------------------------------

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# Google AI
GOOGLE_AI_API_KEY=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# 模型服务配置
# -----------------------------------------------------------------------------

# 默认模型提供商
AGENTOS_DEFAULT_PROVIDER=openai

# 默认模型
AGENTOS_DEFAULT_MODEL=gpt-4-turbo

# 嵌入模型
AGENTOS_EMBEDDING_MODEL=embedding-3-small

# Ollama 本地模型（可选）
OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# 安全配置
# -----------------------------------------------------------------------------

# 安全模式（strict, standard, permissive）
AGENTOS_SECURITY_MODE=standard

# 审计日志启用
AGENTOS_AUDIT_ENABLED=true

# 加密密钥（生产环境必须设置）
AGENTOS_ENCRYPTION_KEY=

# JWT 密钥（生产环境必须设置）
AGENTOS_JWT_SECRET=

# -----------------------------------------------------------------------------
# 网络配置
# -----------------------------------------------------------------------------

# HTTP 代理（可选）
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# 服务监听地址
AGENTOS_BIND_ADDRESS=0.0.0.0

# 默认端口
AGENTOS_HTTP_PORT=8080
AGENTOS_GRPC_PORT=50051

# -----------------------------------------------------------------------------
# 数据库配置（可选）
# -----------------------------------------------------------------------------

# SQLite（默认）
AGENTOS_DB_TYPE=sqlite
AGENTOS_DB_PATH=${AGENTOS_DATA_DIR}/agentos.db

# PostgreSQL（可选）
# AGENTOS_DB_TYPE=postgresql
# AGENTOS_DB_HOST=localhost
# AGENTOS_DB_PORT=5432
# AGENTOS_DB_NAME=agentos
# AGENTOS_DB_USER=agentos
# AGENTOS_DB_PASSWORD=

# -----------------------------------------------------------------------------
# Redis 配置（可选）
# -----------------------------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# 容器配置
# -----------------------------------------------------------------------------

# 容器注册中心
CONTAINER_REGISTRY=docker.io

# 默认容器镜像
AGENTOS_DEFAULT_IMAGE=agentos/runtime:latest

# -----------------------------------------------------------------------------
# 监控配置
# -----------------------------------------------------------------------------

# Prometheus 指标端口
AGENTOS_METRICS_PORT=9090

# Jaeger 追踪端点
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------

# 日志级别（trace, debug, info, warning, error, critical）
AGENTOS_LOG_LEVEL=info

# 日志格式（json, text, color）
AGENTOS_LOG_FORMAT=json

# -----------------------------------------------------------------------------
# 开发配置
# -----------------------------------------------------------------------------

# 调试模式
AGENTOS_DEBUG=false

# 开发模式（启用热重载等）
AGENTOS_DEV_MODE=false

# 配置热更新
AGENTOS_CONFIG_HOT_RELOAD=true

# -----------------------------------------------------------------------------
# 环境标识
# -----------------------------------------------------------------------------

# 运行环境（development, staging, production）
AGENTOS_ENV=development

# 实例 ID（集群部署时需要唯一）
AGENTOS_INSTANCE_ID=

# -----------------------------------------------------------------------------
# Webhook 配置（可选）
# -----------------------------------------------------------------------------

# 安全告警 Webhook
SECURITY_WEBHOOK_URL=

# 审计 Webhook
AUDIT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# 功能开关
# -----------------------------------------------------------------------------

# 启用记忆系统
AGENTOS_MEMORY_ENABLED=true

# 启用向量检索
AGENTOS_VECTOR_SEARCH_ENABLED=true

# 启用任务调度
AGENTOS_SCHEDULER_ENABLED=true

# 启用多 Agent 协作
AGENTOS_MULTI_AGENT_ENABLED=true
