{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Contract",
  "description": "Schema for Agent capability description",
  "type": "object",
  "required": ["agent_id", "role", "version", "capabilities"],
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "Unique identifier for the agent"
    },
    "agent_name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the agent"
    },
    "role": {
      "type": "string",
      "description": "Role category (e.g., product_manager, architect)"
    },
    "description": {
      "type": "string",
      "description": "Brief description of the agent's purpose"
    },
    "capabilities": {
      "type": "array",
      "description": "List of capabilities this agent provides",
      "items": {
        "type": "object",
        "required": ["name", "input_schema", "output_schema"],
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "input_schema": {"type": "object"},
          "output_schema": {"type": "object"},
          "estimated_tokens": {"type": "integer"},
          "avg_duration_ms": {"type": "integer"},
          "success_rate": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "models": {
      "type": "object",
      "properties": {
        "system1": {"type": "string"},
        "system2": {"type": "string"}
      }
    },
    "required_permissions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "cost_profile": {
      "type": "object",
      "properties": {
        "token_per_task_avg": {"type": "integer"},
        "api_cost_per_task": {"type": "number"}
      }
    },
    "trust_metrics": {
      "type": "object",
      "properties": {
        "install_count": {"type": "integer"},
        "rating": {"type": "number"},
        "verified_provider": {"type": "boolean"},
        "last_audit": {"type": "string", "format": "date"}
      }
    }
  }
}