"""
AgentOS Debug & Diagnostics Tool

Usage:
    agentos-debug [command] [options]

Commands:
    check          Full system diagnostics
    gateway        Gateway connectivity & protocol test
    services       Service health & dependency check
    ipc            IPC bus & service discovery test
    metrics        Metrics collection verification
    config         Configuration validation
    circuit        Circuit breaker status check
    alerts         Active alerts inspection
    trace          Distributed trace analysis
    dump           Full diagnostic dump
"""

import sys
import os
import json
import time
import platform
import subprocess
from datetime import datetime
from typing import Dict, List, Optional, Tuple

GATEWAY_URL = os.environ.get("AGENTOS_GATEWAY_URL", "http://localhost:18789")

BOLD = "\033[1m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
BLUE = "\033[34m"
CYAN = "\033[36m"
DIM = "\033[2m"
RESET = "\033[0m"

PASS = f"{GREEN}PASS{RESET}"
FAIL = f"{RED}FAIL{RESET}"
WARN = f"{YELLOW}WARN{RESET}"
SKIP = f"{DIM}SKIP{RESET}"


def http_get(path: str, timeout: int = 5) -> Tuple[int, Dict]:
    import urllib.request
    import urllib.error
    url = f"{GATEWAY_URL}{path}"
    try:
        req = urllib.request.Request(url)
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status, json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        try:
            body = json.loads(e.read().decode())
        except Exception:
            body = {"error": str(e)}
        return e.code, body
    except Exception as e:
        return 0, {"error": str(e)}


def http_post(path: str, data: Dict, timeout: int = 5) -> Tuple[int, Dict]:
    import urllib.request
    import urllib.error
    url = f"{GATEWAY_URL}{path}"
    body = json.dumps(data).encode()
    headers = {"Content-Type": "application/json"}
    req = urllib.request.Request(url, data=body, headers=headers, method="POST")
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status, json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        try:
            body = json.loads(e.read().decode())
        except Exception:
            body = {"error": str(e)}
        return e.code, body
    except Exception as e:
        return 0, {"error": str(e)}


def check_gateway() -> Dict:
    results = {"name": "Gateway Connectivity", "checks": []}

    status, body = http_get("/health")
    if status == 200 and "error" not in body:
        results["checks"].append({
            "name": "Health endpoint",
            "status": "pass",
            "detail": f"Status: {body.get('status', 'ok')}, Version: {body.get('version', '?')}"
        })
    else:
        results["checks"].append({
            "name": "Health endpoint",
            "status": "fail",
            "detail": f"Unreachable at {GATEWAY_URL}: {body.get('error', 'unknown')}"
        })

    start = time.time()
    status, _ = http_get("/health")
    latency = (time.time() - start) * 1000

    results["checks"].append({
        "name": "Response latency",
        "status": "pass" if latency < 100 else "warn" if latency < 500 else "fail",
        "detail": f"{latency:.1f}ms"
    })

    status, body = http_get("/metrics")
    results["checks"].append({
        "name": "Metrics endpoint",
        "status": "pass" if status == 200 else "fail",
        "detail": f"Status: {status}"
    })

    return results


def check_protocols() -> Dict:
    results = {"name": "Protocol Adapters", "checks": []}

    protocols = [
        ("JSON-RPC", "/jsonrpc", {"jsonrpc": "2.0", "id": "1", "method": "service.list", "params": {}}),
        ("MCP", "/mcp", None),
        ("A2A", "/a2a", None),
        ("OpenAI", "/v1/models", None),
    ]

    for name, endpoint, payload in protocols:
        if payload:
            status, body = http_post(endpoint, payload)
        else:
            status, body = http_get(endpoint)

        if status > 0 and status < 500:
            results["checks"].append({
                "name": f"{name} adapter",
                "status": "pass" if status == 200 else "warn",
                "detail": f"HTTP {status}"
            })
        else:
            results["checks"].append({
                "name": f"{name} adapter",
                "status": "fail",
                "detail": body.get("error", "unreachable")
            })

    return results


def check_services() -> Dict:
    results = {"name": "Service Health", "checks": []}

    status, body = http_post("/jsonrpc", {
        "jsonrpc": "2.0", "id": "1", "method": "service.list", "params": {}
    })

    if status == 200 and "result" in body:
        services = body.get("result", {}).get("services", [])
        for svc in services:
            healthy = svc.get("healthy", False)
            results["checks"].append({
                "name": f"Service: {svc.get('name', '?')}",
                "status": "pass" if healthy else "fail",
                "detail": f"Status: {svc.get('status', '?')}"
            })
    else:
        results["checks"].append({
            "name": "Service discovery",
            "status": "fail",
            "detail": body.get("error", "unreachable")
        })

    return results


def check_ipc() -> Dict:
    results = {"name": "IPC & Service Discovery", "checks": []}

    status, body = http_post("/jsonrpc", {
        "jsonrpc": "2.0", "id": "1", "method": "service.discover", "params": {}
    })

    if status == 200:
        endpoints = body.get("result", {}).get("endpoints", [])
        results["checks"].append({
            "name": "Service discovery",
            "status": "pass" if endpoints else "warn",
            "detail": f"{len(endpoints)} endpoints found"
        })
    else:
        results["checks"].append({
            "name": "Service discovery",
            "status": "fail",
            "detail": "Service discovery not available"
        })

    results["checks"].append({
        "name": "IPC service bus",
        "status": "warn",
        "detail": "Requires runtime verification"
    })

    return results


def check_circuit_breakers() -> Dict:
    results = {"name": "Circuit Breakers", "checks": []}

    status, body = http_post("/jsonrpc", {
        "jsonrpc": "2.0", "id": "1", "method": "circuit_breaker.list", "params": {}
    })

    if status == 200 and "result" in body:
        breakers = body.get("result", {}).get("breakers", [])
        for cb in breakers:
            state = cb.get("state", "unknown")
            results["checks"].append({
                "name": f"Breaker: {cb.get('name', '?')}",
                "status": "pass" if state == "closed" else "warn" if state == "half_open" else "fail",
                "detail": f"State: {state}"
            })
    else:
        results["checks"].append({
            "name": "Circuit breaker API",
            "status": "warn",
            "detail": "Circuit breaker status not available via API"
        })

    return results


def check_alerts() -> Dict:
    results = {"name": "Alert System", "checks": []}

    status, body = http_post("/jsonrpc", {
        "jsonrpc": "2.0", "id": "1", "method": "alert.list", "params": {}
    })

    if status == 200 and "result" in body:
        alerts = body.get("result", {}).get("alerts", [])
        active_count = len([a for a in alerts if a.get("state") == "firing"])
        results["checks"].append({
            "name": "Active alerts",
            "status": "pass" if active_count == 0 else "warn" if active_count < 5 else "fail",
            "detail": f"{active_count} active alerts"
        })
    else:
        results["checks"].append({
            "name": "Alert system",
            "status": "warn",
            "detail": "Alert API not available"
        })

    return results


def check_config() -> Dict:
    results = {"name": "Configuration", "checks": []}

    status, body = http_post("/jsonrpc", {
        "jsonrpc": "2.0", "id": "1", "method": "config.list", "params": {}
    })

    if status == 200 and "result" in body:
        entries = body.get("result", {}).get("entries", {})
        count = len(entries) if isinstance(entries, dict) else 0
        results["checks"].append({
            "name": "Configuration loaded",
            "status": "pass" if count > 0 else "warn",
            "detail": f"{count} configuration entries"
        })
    else:
        results["checks"].append({
            "name": "Configuration system",
            "status": "warn",
            "detail": "Config API not available"
        })

    return results


def print_section(results: Dict):
    print(f"\n  {BOLD}{results['name']}{RESET}")
    for check in results.get("checks", []):
        status_str = {
            "pass": PASS,
            "fail": FAIL,
            "warn": WARN,
            "skip": SKIP,
        }.get(check["status"], check["status"])
        print(f"    [{status_str}] {check['name']}: {check['detail']}")


def run_full_check():
    print(f"\n{BOLD}{BLUE}{'=' * 60}{RESET}")
    print(f"{BOLD}{BLUE}  AgentOS Diagnostic Report{RESET}")
    print(f"{BOLD}{BLUE}  {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}{RESET}")
    print(f"{BOLD}{BLUE}{'=' * 60}{RESET}")

    print(f"\n  {BOLD}System Info{RESET}")
    print(f"    OS: {platform.system()} {platform.release()}")
    print(f"    Python: {platform.python_version()}")
    print(f"    Gateway URL: {GATEWAY_URL}")

    sections = [
        check_gateway(),
        check_protocols(),
        check_services(),
        check_ipc(),
        check_circuit_breakers(),
        check_alerts(),
        check_config(),
    ]

    total_pass = 0
    total_fail = 0
    total_warn = 0

    for section in sections:
        print_section(section)
        for check in section.get("checks", []):
            if check["status"] == "pass":
                total_pass += 1
            elif check["status"] == "fail":
                total_fail += 1
            elif check["status"] == "warn":
                total_warn += 1

    print(f"\n  {BOLD}Summary{RESET}")
    print(f"    {GREEN}Passed: {total_pass}{RESET}  {YELLOW}Warnings: {total_warn}{RESET}  {RED}Failed: {total_fail}{RESET}")

    if total_fail > 0:
        print(f"\n  {RED}{BOLD}Action required: {total_fail} check(s) failed{RESET}")
        return 1
    elif total_warn > 0:
        print(f"\n  {YELLOW}{BOLD}Attention: {total_warn} warning(s) found{RESET}")
        return 0
    else:
        print(f"\n  {GREEN}{BOLD}All checks passed!{RESET}")
        return 0


def run_dump():
    print(f"{BOLD}AgentOS Full Diagnostic Dump{RESET}")
    print(f"Timestamp: {datetime.now().isoformat()}")
    print(f"Gateway: {GATEWAY_URL}\n")

    dump = {
        "timestamp": datetime.now().isoformat(),
        "gateway_url": GATEWAY_URL,
        "platform": {
            "system": platform.system(),
            "release": platform.release(),
            "python": platform.python_version(),
        },
        "health": http_get("/health")[1],
        "metrics_available": http_get("/metrics")[0] == 200,
        "protocols": {},
    }

    for proto in ["jsonrpc", "mcp", "a2a", "openai"]:
        status, body = http_get(f"/api/v1/protocols/test?protocol={proto}")
        dump["protocols"][proto] = {"status": status, "body": body}

    print(json.dumps(dump, indent=2, ensure_ascii=False))
    return 0


def main():
    if len(sys.argv) < 2:
        return run_full_check()

    command = sys.argv[1]

    if command == "check":
        return run_full_check()
    elif command == "gateway":
        print_section(check_gateway())
        return 0
    elif command == "protocols":
        print_section(check_protocols())
        return 0
    elif command == "services":
        print_section(check_services())
        return 0
    elif command == "ipc":
        print_section(check_ipc())
        return 0
    elif command == "circuit":
        print_section(check_circuit_breakers())
        return 0
    elif command == "alerts":
        print_section(check_alerts())
        return 0
    elif command == "config":
        print_section(check_config())
        return 0
    elif command == "dump":
        return run_dump()
    else:
        print(f"Unknown command: {command}")
        print("Available: check, gateway, protocols, services, ipc, circuit, alerts, config, dump")
        return 1


if __name__ == "__main__":
    sys.exit(main() or 0)
