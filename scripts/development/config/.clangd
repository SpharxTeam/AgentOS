# AgentOS .clangd 配置文件
# 修复标红问题

CompileFlags:
  Add:
    # 标准 C 版本
    - -std=c11
    # 预处理器定义
    - -D_CRT_SECURE_NO_WARNINGS
    - -DAGENTOS_VERSION="1.0.0.6"
    - -D_GNU_SOURCE
    # Windows 平台兼容定义
    - -Dssize_t=int
    # 抑制 Windows 平台常见警告
    - -Wno-implicit-function-declaration
    # 头文件路径（使用绝对路径）
    - -ID:\Spharx\SpharxWorks\AgentOS
    - -ID:\Spharx\SpharxWorks\AgentOS\atoms\corekern\include
    - -ID:\Spharx\SpharxWorks\AgentOS\atoms\coreloopthree\include
    - -ID:\Spharx\SpharxWorks\AgentOS\atoms\memoryrovol\include
    - -ID:\Spharx\SpharxWorks\AgentOS\atoms\syscall\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\platform\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\config\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\config_unified\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\cost\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\error\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\execution\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\io\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\logging\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\memory\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\network\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\observability\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\platform\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\security
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\string\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\sync\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\token\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\cache\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\cognition\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\compat\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\ipc\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\resource
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\strategy\include
    - -ID:\Spharx\SpharxWorks\AgentOS\commons\utils\types\include

Index:
  StandardLibrary: Yes
  Background: Build

Diagnostics:
  ClangTidy:
    Add:
      - bugprone-*
      - cert-err33-c
      - cert-err34-c
      - clang-analyzer-security*
      - performance-*
    Remove:
      - bugprone-macro-parentheses
      - llvm-header-guard
