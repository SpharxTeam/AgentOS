root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.sh]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4

[*.{md,rst,yml,yaml,json}]
max_line_length = 120
indent_size = 2

[*.ps1]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
