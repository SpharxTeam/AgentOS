# AgentOS Project Specific
# =============================================================================

# CI/CD workflows
.github/** text=eol=lf auto
.gitcode/** text=eol=lf auto

# vcpkg
vcpkg.json text=eol=lf

# Test fixtures
tests/fuzz/** -text
tests/benchmarks/** -text
