# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.cc text eol=lf
*.cxx text eol=lf

# Python
*.py text eol=lf
*.pyx text eol=lf
*.pyd text eol=lf
*.pyw text eol=lf

# Go
*.go text eol=lf

# Rust
*.rs text eol=lf

# TypeScript/JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.md text eol=lf
Makefile text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.env.example text eol=lf
.editorconfig text eol=lf

# Binary files
*.so binary
*.dll binary
*.dylib binary
*.a binary
*.lib binary
*.o binary
*.obj binary
*.exe binary
*.bin binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
