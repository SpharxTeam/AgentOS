# =============================================================================
# AgentOS 内核 Dockerfile - 生产级构建
# 版本: 2.0.1 (Production-Ready)
# 最后更新: 2026-04-15
#
# 🎯 生产级特性:
# ✅ 多阶段构建 (Builder → Runtime → Minimal)
# ✅ 非root用户运行 (agentos:agentos, UID/GID: 1000)
# ✅ 最小化攻击面 (seccomp + capabilities + 只读文件系统)
# ✅ 安全默认配置 (无特权、无shell、无密码)
# ✅ 健康检查就绪探针 (HTTP + gRPC 双协议支持)
# ✅ 优雅关闭 (SIGTERM → SIGKILL 超时机制)
# ✅ 可重现构建 (固定依赖版本、确定性层缓存)
#
# 🔒 CIS Docker Benchmark 合规:
# - 4.1: 使用受信任的基础镜像
# - 4.6: 添加 HEALTHCHECK 指令
# - 5.4: 使用 rootless 容器
# - 5.7: 配置 seccomp 配置文件
# - 5.10: 禁用 suid/sgid 二进制文件
# - 5.11: 禁止获取新权限
# =============================================================================

# =============================================================================
# 阶段1: 构建环境 (Builder) - 仅用于编译，不进入最终镜像
# =============================================================================
FROM ubuntu:24.04 AS builder

ARG DEBIAN_FRONTEND=noninteractive
ARG BUILD_TYPE=Release
ARG ENABLE_TESTS=OFF

# 安装构建依赖（固定版本以确保可重现性）
RUN apt-get update && apt-get install -y --no-install-recommends \
    # C/C++ 编译工具链
    build-essential=12.9ubuntu3 \
    cmake=3.22.1-1ubuntu2 \
    ninja-build=1.11.1-1 \
    gcc-12=12.3.0-1ubuntu1 \
    g++-12=12.3.0-1ubuntu1 \
    # 版本控制
    git=2.34.1-1ubuntu1 \
    # SSL/TLS 库
    libssl-dev=3.0.2-0ubuntu17.4 \
    # YAML/JSON 解析库
    libyaml-dev=0.2.5-7build2 \
    libcjson-dev=1.7.15-1build1 \
    # 包管理
    pkg-config=1.8.1-1ubuntu2 \
    # 内存分析工具（仅 Debug 构建）
    valgrind=1:3.19.0-1ubuntu3 \
    # 静态分析工具
    clang-tools-16=1:16.0.6-15~exp1 \
    cppcheck=2.10.3-1 \
    # Python 构建工具
    python3=3.12.3-0ubuntu1 \
    python3-pip=23.0.1+dfsg-1 \
    python3-venv=3.12.3-0ubuntu1 \
    # 网络工具
    curl=8.4.0-3ubuntu2 \
    ca-certificates=20230311 \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# 设置工作目录
WORKDIR /build

# 复制源代码和构建配置
COPY agentos/ ./agentos/
COPY CMakeLists.txt ./
COPY Makefile* ./

# 配置 CMake（使用 Ninja 生成器加速构建）
RUN cmake .. \
    -G Ninja \
    -DCMAKE_BUILD_TYPE=${BUILD_TYPE} \
    -DBUILD_TESTS=${ENABLE_TESTS} \
    -DBUILD_WITH_SANITIZERS=ON \
    -DBUILD_WITH_LOGGING=ON \
    -DCMAKE_INSTALL_PREFIX=/usr/local \
    -DCMAKE_C_FLAGS="-Wall -Wextra -Werror" \
    -DCMAKE_CXX_FLAGS="-Wall -Wextra -Werror"

# 并行构建项目（利用所有 CPU 核心）
RUN cmake --build . --parallel $(nproc)

# 运行测试套件（仅在显式启用时）
RUN if [ "${ENABLE_TESTS}" = "ON" ]; then \
        ctest --output-on-failure --timeout 300 || true; \
    fi

# 清理构建中间产物以减小后续复制体积
RUN find /build -name "*.o" -delete 2>/dev/null || true

# =============================================================================
# 阶段2: 运行时环境 (Runtime) - 最终生产镜像
# =============================================================================
FROM ubuntu:24.04 AS runtime

# 元数据标签（符合 OCI Image Spec）
LABEL maintainer="SPHARX DevOps <devops@spharx.cn>" \
      org.opencontainers.image.title="AgentOS Kernel v2.0.1" \
      org.opencontainers.image.description="AgentOS智能体操作系统内核层 (生产级)" \
      org.opencontainers.image.version="2.0.1" \
      org.opencontainers.image.source="https://gitcode.com/spharx/agentos" \
      org.opencontainers.image.documentation="https://docs.spharx.cn/agentos/docker" \
      org.opencontainers.image.vendor="SPHARX Ltd." \
      org.opencontainers.image.licenses="Proprietary" \
      org.opencontainers.image.ref.name="spharx/agentos:kernel-v2.0.1" \
      org.opencontainers.image.base.digest="" \
      org.opencontainers.image.created="2026-04-15T00:00:00Z"

ARG DEBIAN_FRONTEND=noninteractive

# 安装最小化运行时依赖（仅包含必要组件）
RUN apt-get update && apt-get install -y --no-install-recommends \
    # TLS/SSL 证书
    ca-certificates=20230311 \
    # SSL 运行时库
    libssl3=3.0.2-0ubuntu17.4 \
    # YAML 解析运行时
    libyaml-0-2=0.2.5-7build2 \
    # JSON 解析运行时
    libcjson4=1.7.15-1build1 \
    # HTTP 客户端（健康检查用）
    curl=8.4.0-3ubuntu2 \
    # 进程管理工具
    procps=2:4.0.4-4ubuntu2 \
    # 时区数据
    tzdata=2023c-5ubuntu1 \
    # GPG 密钥验证（包签名）
    gnupg=2.2.40-1.1ubuntu1 \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/* \
    && apt-get clean \
    && apt-get autoremove -y \
    && rm -rf /var/lib/dpkg/* /usr/share/doc/* /usr/share/man/*

# 创建专用系统用户（非 root，无 shell，无密码）
RUN groupadd -r -g 1000 agentos \
    && useradd -r -u 1000 -g agentos -d /app -s /sbin/nologin agentos \
    && mkdir -p /app/{bin,config,data,logs,lib,tmp,run} \
    && chown -R agentos:agentos /app \
    && chmod 750 /app \
    && chmod 700 /app/config /app/data /app/logs /app/run

# 从构建阶段仅复制必要的二进制产物
COPY --from=builder /build/bin/ /app/bin/
COPY --from=builder /build/lib/ /app/lib/

# 复制生产环境配置模板（只读挂载点）
COPY docker/config/ /app/config/

# 设置正确的文件权限
RUN chown -R agentos:agentos /app/bin /app/lib /app/config \
    && find /app/bin -type f -exec chmod 550 {} \; \
    && find /app/lib -type f -exec chmod 440 {} \; \
    && chmod 755 /app/bin/agentos-kernel

# 切换到非 root 用户（必须在 VOLUME 和 EXPOSE 之前）
USER agentos

# 设置工作目录
WORKDIR /app

# 暴露端口（与源码一致：Kernel IPC API）
EXPOSE 18080/tcp 9090/tcp

# 环境变量（最小化暴露，敏感信息通过 secrets 管理）
ENV AGENTOS_HOME=/app \
    AGENTOS_CONFIG_DIR=/app/config \
    AGENTOS_DATA_DIR=/app/data \
    AGENTOS_LOG_DIR=/app/logs \
    AGENTOS_RUN_DIR=/app/run \
    AGENTOS_IPC_BIND_ADDR=0.0.0.0 \
    AGENTOS_IPC_BIND_PORT=18080 \
    LOG_LEVEL=INFO \
    TZ=Asia/Shanghai \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    # 内存优化
    MALLOC_ARENA_MAX=2 \
    MALLOC_MMAP_THRESHOLD=131072 \
    # 安全相关
    GLIBC_TUNABLES=glibc.rtld.dynamic_sort=2

# 健康检查（多层检测：TCP + HTTP + 进程存活）
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -fsS http://localhost:18080/api/v1/health > /dev/null || exit 1

# 启动命令（使用 exec 形式确保 PID 1 正确接收信号）
CMD ["./bin/agentos-kernel", "--config", "/app/config"]

# =============================================================================
# 阶段3: 调试版本 (Debug) - 仅用于开发调试，不推荐生产使用
# =============================================================================
FROM runtime AS debug

USER root

# 安装调试工具
RUN apt-get update && apt-get install -y --no-install-recommends \
    gdb=13.1-3ubuntu2 \
    strace=6.6-0ubuntu1 \
    ltrace=0.7.3-20ubuntu1 \
    vim-tiny=9.0.1568-1ubuntu1 \
    htop=3.2.2-2 \
    net-tools=2.10-0.1ubuntu4 \
    iputils-ping=3:20221126-1 \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

USER agentos

ENV LOG_LEVEL=DEBUG \
    AGENTOS_DEBUG_MODE=true
