# =============================================================================
# AgentOS Docker 环境变量配置示例
# 版本: 1.0.0
#
# 使用方法:
#   cp docker/.env.example docker/.env
#   # 然后编辑 .env 文件，填入实际值
#
# 注意:
#   - 不要将包含敏感信息的 .env 文件提交到版本控制
#   - 生产环境请使用 Docker Secrets 或 Kubernetes Secrets
# =============================================================================

# -----------------------------------------------------------------------------
# 通用配置 (General)
# -----------------------------------------------------------------------------

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 时区
TZ=Asia/Shanghai

# 语言
LANG=en_US.UTF-8

# AgentOS版本号（用于Docker镜像标签）
AGENTOS_VERSION=1.0.0

# -----------------------------------------------------------------------------
# 内核服务配置 (Kernel)
# -----------------------------------------------------------------------------

# IPC绑定地址
AGENTOS_IPC_BIND_ADDR=0.0.0.0

# IPC绑定端口
KERNEL_IPC_PORT=8080

# Prometheus监控端口
KERNEL_METRICS_PORT=9090

# 最大并发连接数（生产环境建议：10000）
MAX_CONNECTIONS=10000

# 内存限制(MB)（生产环境建议：8192）
MEMORY_LIMIT=8192

# CPU核心数限制
CPU_CORES=8

# Docker资源限制
CPU_LIMIT=4
CPU_RESERVATION=2
MEMORY_RESERVATION=2G

# 内核实例数量（用于水平扩展）
KERNEL_REPLICAS=1

# -----------------------------------------------------------------------------
# 守护进程配置 (Daemon)
# -----------------------------------------------------------------------------

# 守护进程实例数量
DAEMON_REPLICAS=1

# -----------------------------------------------------------------------------
# 数据库配置 (PostgreSQL)
# -----------------------------------------------------------------------------

# PostgreSQL端口
POSTGRES_PORT=5432

# 数据库名称
POSTGRES_DB=agentos

# 数据库用户名
POSTGRES_USER=agentos

# ⚠️  生产环境必须修改此密码！
POSTGRES_PASSWORD=change_me_in_production

# PostgreSQL性能调优参数
PG_MAX_CONNECTIONS=200
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE_SIZE=1GB
PG_WORK_MEM=4MB
PG_MAINTENANCE_WORK_MEM=64MB

# 完整数据库连接字符串（优先级高于上述单独配置）
DATABASE_URL=postgresql://agentos:change_me_in_production@postgres:5432/agentos

# -----------------------------------------------------------------------------
# Redis缓存配置 (Redis)
# -----------------------------------------------------------------------------

# Redis端口
REDIS_PORT=6379

# ⚠️  生产环境必须修改此密码！
REDIS_PASSWORD=change_me_in_production

# Redis最大内存(MB)
REDIS_MAX_MEMORY=512mb

# -----------------------------------------------------------------------------
# 记忆系统配置 (Memory System)
# -----------------------------------------------------------------------------

# L1存储路径
AGENTOS_L1_STORAGE_PATH=/app/data/memory/l1

# L2索引类型: faiss_ivf, faiss_hnsw
AGENTOS_L2_INDEX_TYPE=faiss_ivf

# FAISS分区数
AGENTOS_FAISS_NLIST=1024

# FAISS探测数
AGENTOS_FAISS_NPROBE=32

# 向量维度
AGENTOS_EMBEDDING_DIM=768

# -----------------------------------------------------------------------------
# 安全配置 (Security - Cupolas)
# -----------------------------------------------------------------------------

# 启用安全穹顶
AGENTOS_CUPOLAS_ENABLED=true

# 权限检查模式: strict, relaxed, disabled
AGENTOS_PERMISSION_MODE=strict

# 输入净化模式: strict, relaxed, disabled
AGENTOS_SANITIZER_MODE=strict

# 启用审计日志
AGENTOS_AUDIT_ENABLED=true

# 审计日志路径
AGENTOS_AUDIT_LOG_PATH=/app/logs/audit.log

# -----------------------------------------------------------------------------
# LLM服务配置 (LLM Service)
# -----------------------------------------------------------------------------

# LLM提供商: openai, deepseek, local
AGENTOS_LLM_PROVIDER=openai

# API密钥（⚠️ 生产环境使用secrets管理）
AGENTOS_LLM_API_KEY=sk-your-api-key-here

# API基础URL
AGENTOS_LLM_BASE_URL=https://api.openai.com/v1

# 模型名称
AGENTOS_LLM_MODEL=gpt-4-turbo

# 最大Token数
AGENTOS_LLM_MAX_TOKENS=4096

# 温度参数
AGENTOS_LLM_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# OpenLab配置 (OpenLab Web Application)
# -----------------------------------------------------------------------------

# OpenLab Web端口（HTTPS）
OPENLAB_WEB_PORT=443

# OpenLab API端口
OPENLAB_API_PORT=8000

# 允许的CORS来源
OPENLAB_CORS_ORIGINS=https://openlab.spharx.cn,https://your-domain.com

# 会话超时(秒)
SESSION_TIMEOUT=3600

# 最大会话数
OPENLAB_MAX_SESSIONS=1000

# ⚠️  生产环境必须设置此密钥！（用于会话加密）
OPENLAB_SECRET_KEY=change_me_to_a_random_secret_key_at_least_32_chars

# -----------------------------------------------------------------------------
# 监控配置 (Monitoring Stack)
# -----------------------------------------------------------------------------

# Prometheus端口
PROMETHEUS_PORT=9091

# Prometheus数据保留时间
PROMETHEUS_RETENTION=30d

# Prometheus数据保留大小
PROMETHEUS_RETENTION_SIZE=20GB

# Grafana端口
GRAFANA_PORT=3000

# Grafana管理员用户名
GRAFANA_ADMIN_USER=admin

# ⚠️  生产环境必须设置Grafana管理员密码！
GRAFANA_ADMIN_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# Docker网络配置 (Network)
# -----------------------------------------------------------------------------

# Docker网络子网
DOCKER_NETWORK_SUBNET=172.28.0.0/16

# -----------------------------------------------------------------------------
# 数据卷持久化路径 (Data Volumes)
# -----------------------------------------------------------------------------

# 数据存储根目录（所有服务的持久化数据将存储在此目录下）
DATA_VOLUME_PATH=./data

# -----------------------------------------------------------------------------
# 性能调优 (Performance Tuning)
# -----------------------------------------------------------------------------

# 工作线程数（默认为CPU核心数）
WORKER_THREADS=8

# 连接池大小
CONNECTION_POOL_SIZE=20

# 请求超时时间(秒)
REQUEST_TIMEOUT=30

# 响应缓冲区大小(KB)
RESPONSE_BUFFER_SIZE=64

# -----------------------------------------------------------------------------
# 日志配置 (Logging)
# -----------------------------------------------------------------------------

# 日志文件最大大小(MB)
LOG_FILE_MAX_SIZE=100

# 日志文件最大数量
LOG_FILE_MAX_COUNT=5

# 是否输出到控制台
LOG_TO_CONSOLE=true

# 是否输出到文件
LOG_TO_FILE=true

# -----------------------------------------------------------------------------
# 调试配置 (Debug - 仅开发环境启用)
# -----------------------------------------------------------------------------

# 是否启用调试模式（生产环境必须为false）
DEBUG_MODE=false

# 是否启用性能分析
ENABLE_PROFILING=false

# 是否启用内存泄漏检测
ENABLE_MEMORY_LEAK_DETECTION=false
