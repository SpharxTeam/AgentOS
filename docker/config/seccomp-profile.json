# =============================================================================
# seccomp 安全配置文件 - AgentOS 内核容器
# 版本: 1.0.0
# 用途: 限制容器内可用的系统调用，增强安全性
#
# 设计原则:
# 1. 默认拒绝所有系统调用
# 2. 仅允许必要的系统调用白名单
# 3. 基于最小权限原则
# =============================================================================

{
    "defaultAction": "SCMP_ACT_ERRNO",
    "architectures": [
        "SCMP_ARCH_X86_64",
        "SCMP_ARCH_AARCH64"
    ],
    "syscalls": [
        # =========================================================================
        # 文件操作 (File Operations)
        # =========================================================================
        {
            "names": [
                "read",
                "write",
                "open",
                "openat",
                "close",
                "stat",
                "fstat",
                "lstat",
                "fstatat",
                "access",
                "faccessat",
                "chmod",
                "fchmod",
                "chown",
                "fchown",
                "lseek",
                "dup",
                "dup2",
                "dup3",
                "fcntl",
                "ioctl",
                "fsync",
                "fdatasync",
                "sync",
                "syncfs",
                "ftruncate",
                "truncate",
                "mkdir",
                "mkdirat",
                "rmdir",
                "unlink",
                "unlinkat",
                "rename",
                "renameat",
                "link",
                "symlink",
                "readlink",
                "getdents",
                "getdents64"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 内存管理 (Memory Management)
        # =========================================================================
        {
            "names": [
                "brk",
                "mmap",
                "munmap",
                "mprotect",
                "mremap",
                "msync",
                "mlock",
                "munlock",
                "madvise",
                "mbind",
                "set_robust_list",
                "get_robust_list"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 网络操作 (Network Operations)
        # =========================================================================
        {
            "names": [
                "socket",
                "socketpair",
                "bind",
                "listen",
                "accept",
                "accept4",
                "connect",
                "shutdown",
                "getsockname",
                "getpeername",
                "getsockopt",
                "setsockopt",
                "sendto",
                "recvfrom",
                "sendmsg",
                "recvmsg",
                "sendmmsg",
                "recvmmsg"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 进程控制 (Process Control)
        # =========================================================================
        {
            "names": [
                "clone",
                "fork",
                "vfork",
                "execve",
                "execveat",
                "exit",
                "exit_group",
                "wait4",
                "waitid",
                "waitpid",
                "kill",
                "tgkill",
                "tkill",
                "setsid",
                "setpgid",
                "getpid",
                "getppid",
                "gettid",
                "getpgrp",
                "getsid",
                "prctl",
                "arch_prctl",
                "unshare",
                "setns",
                "personality"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 时间和定时器 (Time & Timers)
        # =========================================================================
        {
            "names": [
                "time",
                "gettimeofday",
                "clock_gettime",
                "clock_getres",
                "clock_nanosleep",
                "nanosleep",
                "alarm",
                "setitimer",
                "getitimer",
                "timer_create",
                "timer_settime",
                "timer_gettime",
                "timer_delete",
                "timerfd_create",
                "timerfd_settime",
                "timerfd_gettime",
                "epoll_create",
                "epoll_create1",
                "epoll_ctl",
                "epoll_wait",
                "epoll_pwait",
                "poll",
                "ppoll",
                "select",
                "pselect6"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 信号处理 (Signal Handling)
        # =========================================================================
        {
            "names": [
                "sigaction",
                "sigprocmask",
                "sigpending",
                "sigsuspend",
                "rt_sigaction",
                "rt_sigprocmask",
                "rt_sigtimedwait",
                "rt_sigpending",
                "rt_sigsuspend",
                "signaldeliver",
                "sigaltstack"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 线程操作 (Thread Operations)
        # =========================================================================
        {
            "names": [
                "pthread_create",
                "pthread_exit",
                "pthread_join",
                "pthread_detach",
                "pthread_cancel",
                "pthread_kill",
                "pthread_sigmask",
                "pthread_equal",
                "pthread_self",
                "sched_yield",
                "sched_setscheduler",
                "sched_getscheduler",
                "sched_setparam",
                "sched_getparam",
                "sched_get_priority_max",
                "sched_get_priority_min",
                "setpriority",
                "getpriority",
                "sched_getaffinity",
                "sched_setaffinity"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 共享内存和 IPC (Shared Memory & IPC)
        # =========================================================================
        {
            "names": [
                "shmget",
                "shmat",
                "shmdt",
                "shmctl",
                "semget",
                "semop",
                "semtimedop",
                "semctl",
                "msgget",
                "msgrcv",
                "msgsnd",
                "msgctl",
                "eventfd",
                "eventfd2",
                "pipe",
                "pipe2",
                "tee",
                "splice",
                "vmsplice"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 用户/组信息 (User/Group Information)
        # =========================================================================
        {
            "names": [
                "getuid",
                "getgid",
                "geteuid",
                "getegid",
                "setuid",
                "setgid",
                "seteuid",
                "setegid",
                "setresuid",
                "setresgid",
                "getgroups",
                "setgroups",
                "getresuid",
                "getresgid"
            ],
            "action": "SCMP_ACT_ALLOW"
        },

        # =========================================================================
        # 其他必要调用 (Other Required Syscalls)
        # =========================================================================
        {
            "names": [
                "uname",
                "sysinfo",
                "gethostname",
                "getdomainname",
                "rlimit",
                "getrlimit",
                "setrlimit",
                "prlimit64",
                "umask",
                "chdir",
                "fchdir",
                "getcwd",
                "readlinkat",
                "faccessat2",
                "newfstatat",
                "statx",
                "copy_file_range",
                "pread64",
                "pwrite64",
                "preadv2",
                "pwritev2",
                "process_vm_readv",
                "process_vm_writev",
                "io_setup",
                "io_submit",
                "io_cancel",
                "io_destroy",
                "io_getevents",
                "ioprio_set",
                "ioprio_get",
                "memfd_create",
                "userfaultfd"
            ],
            "action": "SCMP_ACT_ALLOW"
        }
    ]
}
