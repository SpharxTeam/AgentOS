# =============================================================================
# AgentOS Daemon Dockerfile
# 版本: 1.0.0
# 最后更新: 2026-04-05
#
# 设计原则:
# 1. 轻量级运行时：仅包含运行时依赖
# 2. 多服务支持：llm_d, market_d, monit_d, sched_d, tool_d, gateway_d
# 3. 进程管理：使用supervisor管理多个守护进程
# 4. 安全默认配置：非root用户、最小权限
# =============================================================================

# =============================================================================
# 阶段1: 构建环境 (Builder)
# =============================================================================
FROM ubuntu:22.04 AS builder

ARG DEBIAN_FRONTEND=noninteractive
ARG DAEMON_SERVICES=all

# 安装构建依赖
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ninja-build \
    gcc \
    g++ \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    git \
    libssl-dev \
    libyaml-dev \
    libcjson-dev \
    libpq-dev \
    pkg-config \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# 复制守护进程源码
COPY agentos/daemon/ ./agentos/daemon/
COPY agentos/toolkit/python/ ./agentos/toolkit/python/

# 创建虚拟环境并安装Python依赖
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# 安装Python SDK和守护进程依赖
RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
    && cd agentos/toolkit/python \
    && pip install --no-cache-dir -e . \
    && cd ../../daemon \
    && pip install --no-cache-dir -r requirements.txt

# 构建C/C++组件（如果存在）
RUN if [ -f CMakeLists.txt ]; then \
        cmake . -G Ninja -DCMAKE_BUILD_TYPE=Release \
        && cmake --build . --parallel $(nproc); \
    fi

# =============================================================================
# 阶段2: 运行时环境 (Runtime)
# =============================================================================
FROM ubuntu:22.04 AS runtime

LABEL maintainer="SPHARX Ltd. <devops@spharx.cn>"
LABEL org.opencontainers.image.title="AgentOS Daemon Services"
LABEL org.opencontainers.image.description="AgentOS守护进程服务层"
LABEL org.opencontainers.image.version="1.0.0"
LABEL org.opencontainers.image.source="https://gitcode.com/spharx/agentos"

# 安装运行时依赖和进程管理器
RUN apt-get update && apt-get install -y --no-install-recommends \
    supervisor \
    curl \
    ca-certificates \
    libssl3 \
    libyaml-0-2 \
    libcjson4 \
    libpq5 \
    procps \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean \
    && groupadd -r agentos \
    && useradd -r -g agentos -d /app -s /bin/bash agentos

# 从构建阶段复制虚拟环境和构建产物
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY --from=builder /build/bin/ /app/bin/ 2>/dev/null || true
COPY --from=builder /build/lib/ /app/lib/ 2>/dev/null || true

# 创建应用目录结构
RUN mkdir -p /app/{bin,config,data,logs,run,supervisor/conf.d} \
    && chown -R agentos:agentos /app

# 复制supervisor配置模板
COPY docker/config/supervisor/supervisord.conf /etc/supervisor/supervisord.conf
COPY docker/config/supervisor/conf.d/*.conf /app/supervisor/conf.d/ 2>/dev/null || true

# 设置工作目录
WORKDIR /app

# 切换到非root用户
USER agentos

# 暴露端口（各守护进程）
EXPOSE 8001 8002 8003 8004 8005 8006

# 环境变量
ENV AGENTOS_HOME=/app \
    AGENTOS_CONFIG_DIR=/app/config \
    AGENTOS_DATA_DIR=/app/data \
    AGENTOS_LOG_DIR=/app/logs \
    AGENTOS_RUN_DIR=/app/run \
    AGENTOS_KERNEL_URL=http://localhost:8080 \
    LOG_LEVEL=INFO \
    TZ=Asia/Shanghai

# 健康检查（检查关键守护进程是否运行）
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD pgrep -f "supervisord" > /dev/null || exit 1

# 启动命令：使用supervisor管理所有守护进程
CMD ["supervisord", "-c", "/etc/supervisor/supervisord.conf"]
