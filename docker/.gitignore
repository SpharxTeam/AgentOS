# =============================================================================
# AgentOS Docker .gitignore
# 版本: 1.0.0
# 用途: 排除Docker相关的不需要版本控制的文件
# =============================================================================

# -----------------------------------------------------------------------------
# 环境变量文件（包含敏感信息，绝对不能提交）
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging

# -----------------------------------------------------------------------------
# Docker生成的文件和目录
# -----------------------------------------------------------------------------
docker/data/
docker/logs/

# Docker卷数据（本地持久化）
data/
*.tar.gz
*.tar
*.sql

# -----------------------------------------------------------------------------
# 证书和密钥（绝对不能提交）
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.csr
*.p12
*.jks
keystore/
ssl/
certs/

# -----------------------------------------------------------------------------
# 监控配置中的敏感信息
# -----------------------------------------------------------------------------
monitoring/grafana/provisioning/datasources/*.yaml
!monitoring/grafana/provisioning/datasources/datasource.yml.template

# -----------------------------------------------------------------------------
# 构建产物缓存
# -----------------------------------------------------------------------------
.docker/
build/
dist/
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
opt/venv/

# C/C++构建产物
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.o
*.a
*.so
*.dylib

# Go构建产物
vendor/

# Rust构建产物
target/

# -----------------------------------------------------------------------------
# IDE和编辑器配置
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# 日志文件
# -----------------------------------------------------------------------------
*.log
logs/
*.log.*

# -----------------------------------------------------------------------------
# 测试覆盖率报告
# -----------------------------------------------------------------------------
coverage/
.coverage
htmlcov/
.nyc_output/

# -----------------------------------------------------------------------------
# 临时文件
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# 操作系统文件
# -----------------------------------------------------------------------------
Thumbs.db
Desktop.ini
