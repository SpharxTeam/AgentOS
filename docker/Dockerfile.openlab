# =============================================================================
# AgentOS OpenLab Dockerfile
# 版本: 1.0.0
# 最后更新: 2026-04-05
#
# 设计原则:
# 1. 多阶段构建：前端构建 + 后端运行时分离
# 2. 安全默认配置：非root用户、最小依赖
# 3. 生产优化：Nginx反向代理 + Gzip压缩
# =============================================================================

# =============================================================================
# 阶段1: 前端构建 (Frontend Builder)
# =============================================================================
FROM node:20-alpine AS frontend-builder

WORKDIR /app/frontend

# 复制前端源码
COPY openlab/package.json openlab/yarn.lock* ./

# 安装依赖（利用Docker缓存）
RUN yarn install --frozen-lockfile || npm install

# 复制剩余源码并构建
COPY openlab/ ./

# 构建生产版本
RUN yarn build || npm run build

# =============================================================================
# 阶段2: 后端构建 (Backend Builder)
# =============================================================================
FROM python:3.11-slim AS backend-builder

WORKDIR /app/backend

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# 复制后端依赖文件
COPY openlab/backend/requirements.txt ./

# 创建虚拟环境并安装Python依赖
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
RUN pip install --no-cache-dir -r requirements.txt

# =============================================================================
# 阶段3: 运行时环境 (Runtime - Production)
# =============================================================================
FROM python:3.11-slim AS production

LABEL maintainer="SPHARX Ltd. <devops@spharx.cn>"
LABEL org.opencontainers.image.title="AgentOS OpenLab"
LABEL org.opencontainers.image.description="AgentOS智能体交互平台"
LABEL org.opencontainers.image.version="1.0.0"
LABEL org.opencontainers.image.source="https://gitcode.com/spharx/agentos"

# 安装运行时依赖和Nginx
RUN apt-get update && apt-get install -y --no-install-recommends \
    nginx \
    curl \
    ca-certificates \
    libpq5 \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean \
    && groupadd -r openlab \
    && useradd -r -g openlab -d /app -s /bin/bash openlab

# 从后端构建阶段复制虚拟环境
COPY --from=backend-builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# 创建应用目录结构
RUN mkdir -p /app/{frontend,backend,config,data,logs} \
    && chown -R openlab:openlab /app

# 从前端构建阶段复制静态文件
COPY --from=frontend-builder /app/frontend/dist /app/frontend/dist

# 复制后端应用代码
COPY openlab/backend/ /app/backend/

# 复制Nginx配置
COPY docker/config/nginx/openlab.conf /etc/nginx/sites-available/default

# 配置Nginx
RUN ln -sf /dev/stdout /var/log/nginx/access.log \
    && ln -sf /dev/stderr /var/log/nginx/error.log

# 设置工作目录
WORKDIR /app

# 切换到非root用户
USER openlab

# 暴露端口
EXPOSE 443 8000

# 环境变量
ENV OPENLAB_HOME=/app \
    OPENLAB_CONFIG_DIR=/app/config \
    OPENLAB_DATA_DIR=/app/data \
    OPENLAB_LOG_DIR=/app/logs \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

# 启动命令：同时启动Nginx和后端API
CMD ["/bin/sh", "-c", "nginx && cd /app/backend && uvicorn main:app --host 0.0.0.0 --port 8000"]

# =============================================================================
# 阶段4: 开发环境 (Development)
# =============================================================================
FROM node:20-alpine AS development

LABEL stage="development"

WORKDIR /app

# 安装开发工具
RUN apk add --no-cache python3 py3-pip gcc musl-dev postgresql-dev

# 复制完整源码
COPY openlab/ ./openlab/

# 安装所有依赖（包括开发依赖）
WORKDIR /app/openlab
RUN yarn install --frozen-lockfile || npm install

# 暴露端口
EXPOSE 5173 8000

# 环境变量
ENV NODE_ENV=development \
    OPENLAB_DEBUG=true

# 开发启动命令
CMD ["yarn", "dev", "--", "--host", "0.0.0.0"]
