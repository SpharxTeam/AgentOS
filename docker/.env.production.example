# =============================================================================
# AgentOS 生产环境变量配置模板 (Production Environment Template)
# 版本: 2.0.0 (Production-Grade)
# 最后更新: 2026-04-06
#
# ⚠️ 重要安全警告:
# 1. 复制此文件为 .env.production: cp .env.production.example .env.production
# 2. 编辑 .env.production 并替换所有占位符为真实值
# 3. 绝对不要将 .env.production 提交到版本控制系统！
# 4. 所有密码必须使用强随机值（建议使用 openssl 或 pwgen 生成）
# 5. 定期轮换密钥和密码（建议每 90 天）
#
# 🔐 密码生成命令示例:
#   # PostgreSQL 密码 (32字符 alphanumeric + special)
#   openssl rand -base64 32 | tr -d '\n' | head -c 32; echo
#
#   # Redis 密码 (64字符 hex)
#   openssl rand -hex 32
#
#   # JWT Secret (256位 base64url, 至少 43 字符)
#   openssl rand -base64 48 | tr -d '\n=' | head -c 43; echo
#
#   # OpenLab Secret Key (Django 风格, 50 字符)
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
#
# 使用方法:
#   docker compose -f docker/docker-compose.prod.yml --env-file .env.production up -d
# =============================================================================

# -----------------------------------------------------------------------------
# 通用配置 (General Configuration)
# -----------------------------------------------------------------------------

# 日志级别 (生产使用 INFO，避免 DEBUG 泄露敏感信息)
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 时区设置
TZ=Asia/Shanghai

# 语言和字符集
LANG=C.UTF-8
LC_ALL=C.UTF-8

# AgentOS 版本号 (用于 Docker 镜像标签)
AGENTOS_VERSION=2.0.0

# 日志配置
LOG_MAX_SIZE=100m                           # 单个日志文件最大大小
LOG_MAX_FILE=5                              # 保留的日志文件数量

# 网络子网配置 (避免与现有网络冲突)
BACKEND_SUBNET=172.30.0.0/16               # 后端服务子网
FRONTEND_SUBNET=172.31.0.0/16              # 前端服务子网

# -----------------------------------------------------------------------------
# Gateway 服务配置 (Gateway Service)
# -----------------------------------------------------------------------------

# 对外暴露端口
GATEWAY_PORT=18789                          # 主 API 端口 (HTTP + WebSocket)
GATEWAY_ADMIN_PORT=18790                   # 管理 API 端口 (限制 IP 访问)

# JWT 认证密钥 (⚠️ 必须修改为强随机值!)
# 生成命令: openssl rand -base64 48 | tr -d '\n=' | head -c 43; echo
GATEWAY_JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_MIN_43_CHARS_2024

# JWT 配置
TOKEN_EXPIRY_HOURS=8                       # Access Token 有效期 (小时)
REFRESH_TOKEN_DAYS=7                        # Refresh Token 有效期 (天)

# 速率限制 (防 DDoS 和滥用)
GATEWAY_GLOBAL_QPS=5000                    # 全局每秒请求数上限
GATEWAY_PER_IP_QPS=50                      # 单 IP 每秒请求数上限

# Gateway 实例数 (水平扩展，需前置负载均衡器)
GATEWAY_REPLICAS=1

# -----------------------------------------------------------------------------
# 内核服务配置 (Kernel Service)
# -----------------------------------------------------------------------------

# Kernel IPC 端口 (仅内网访问，不对外暴露)
KERNEL_IPC_PORT=18080                      # 内核 IPC API 端口
KERNEL_METRICS_PORT=9090                   # Prometheus Metrics 端口

# 资源限制
CPU_LIMIT=4                                # 最大 CPU 核心数
CPU_RESERVATION=2                          # 保留 CPU 核心数
MEMORY_LIMIT=4G                            # 最大内存
MEMORY_RESERVATION=2G                      # 保留内存

# 连接池配置
MAX_CONNECTIONS=10000                      # 最大并发连接数
MEMORY_LIMIT_MB=8192                       # 内存限制 (MB)
CPU_CORES=8                                # CPU 核心数

# Kernel 实例数 (水平扩展)
KERNEL_REPLICAS=1

# HeapStore 数据分区配置
HEAPSTORE_MAX_LOG_SIZE_MB=500              # 单个日志文件最大 (MB)
HEAPSTORE_LOG_RETENTION_DAYS=90            # 日志保留天数
HEAPSTORE_CIRCUIT_THRESHOLD=10             # 熔断阈值 (连续失败次数)
HEAPSTORE_CIRCUIT_TIMEOUT_SEC=60           # 熔断恢复超时 (秒)

# -----------------------------------------------------------------------------
# PostgreSQL 数据库配置 (PostgreSQL Database)
# -----------------------------------------------------------------------------

# 数据库连接参数
POSTGRES_DB=agentos                        # 数据库名称
POSTGRES_USER=agentos                      # 数据库用户名

# ⚠️ 数据库密码 (必须修改为强随机值!)
# 生成命令: openssl rand -base64 32 | tr -d '\n' | head -c 32; echo
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD_MIN_32_CHARS

# PostgreSQL 端口 (生产环境默认不对外暴露，取消注释以启用)
# POSTGRES_PORT=5432

# PostgreSQL 性能调优
PG_MAX_CONNECTIONS=200                     # 最大连接数
PG_SHARED_BUFFERS=256MB                    # 共享缓冲区
PG_EFFECTIVE_CACHE_SIZE=1GB                # 有效缓存大小
PG_WORK_MEM=4MB                            # 排序/哈希操作内存
PG_MAINTENANCE_WORK_MEM=64MB               # 维护操作内存
PG_CPU_LIMIT=4                             # CPU 上限
PG_MEMORY_LIMIT=4G                         # 内存上限
PG_CPU_RESERVATION=1                       # CPU 保留
PG_MEMORY_RESERVATION=1G                   # 内存保留

# 慢查询阈值 (毫秒，超过此时间的 SQL 将被记录)
PG_SLOW_QUERY_MS=1000

# -----------------------------------------------------------------------------
# Redis 缓存配置 (Redis Cache)
# -----------------------------------------------------------------------------

# ⚠️ Redis 密码 (必须修改为强随机值!)
# 生成命令: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD_64_HEX_CHARS

# Redis 端口 (生产环境默认不对外暴露)
# REDIS_PORT=6379

# Redis 内存配置
REDIS_MAX_MEMORY=1024mb                   # 最大内存使用量 (1GB)

# Redis 性能调优
REDIS_CPU_LIMIT=2                         # CPU 上限
REDIS_MEMORY_LIMIT=2G                     # 内存上限
REDIS_CPU_RESERVATION=0.5                 # CPU 保留
REDIS_MEMORY_RESERVATION=256M             # 内存保留

# -----------------------------------------------------------------------------
# OpenLab 应用配置 (OpenLab Application) [可选]
# -----------------------------------------------------------------------------

# OpenLab 端口
OPENLAB_WEB_PORT=443                       # Web 前端端口 (HTTPS)
OPENLAB_API_PORT=8000                      # API 后端端口

# ⚠️ 应用密钥 (必须修改为强随机值!)
# 生成命令: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
OPENLAB_SECRET_KEY=CHANGE_ME_OPENLAB_SECRET_KEY_MIN_50_CHARS_URLSAFE

# 会话超时 (秒)
SESSION_TIMEOUT=3600                       # 1 小时

# 数据库连接字符串 (PostgreSQL + Redis)
# 格式: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://agentos:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/agentos

# Redis 连接字符串 (含密码)
# 格式: redis://:password@host:port/db
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# -----------------------------------------------------------------------------
# Prometheus 监控配置 (Prometheus Monitoring)
# -----------------------------------------------------------------------------

# Prometheus 端口 (仅本地访问)
PROMETHEUS_PORT=9091                       # Web UI 端口 (偏移避免冲突)

# TSDB 时序数据保留策略
PROMETHEUS_RETENTION=30d                   # 保留时间 (30天)
PROMETHEUS_RETENTION_SIZE=20GB             # 最大存储空间 (20GB)

# -----------------------------------------------------------------------------
# Grafana 可视化配置 (Grafana Visualization)
# -----------------------------------------------------------------------------

# Grafana 端口
GRAFANA_PORT=3000                          # Web UI 端口

# ⚠️ Grafana 管理员密码 (必须修改!)
GRAFANA_ADMIN_USER=admin                   # 管理员账号
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD

# -----------------------------------------------------------------------------
# 高级配置 (Advanced Configuration) [可选]
# -----------------------------------------------------------------------------

# Docker Compose 特定配置
COMPOSE_PROJECT_NAME=agentos-prod          # 项目名称 (容器名前缀)
COMPOSE_HTTP_TIMEOUT=300                   # Compose API 超时 (秒)

# 备份配置
AGENTOS_BACKUP_DIR=/data/backups/agentos   # 备份根目录

# 安全加固选项 (不建议修改)
# CIS_DOCKER_BENCHMARK=true                # 启用 CIS Benchmark 检查
# SECCOMP_PROFILE=./config/seccomp-profile.json
