# =============================================================================
# AgentOS Docker Ignore 文件
# 版本: 1.0.0
# 用途: 排除不需要包含在 Docker 镜像中的文件和目录
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# IDE 和编辑器
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.c9/
.settings/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 虚拟环境
.venv/
venv/
ENV/
env/
.conda/
conda/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 测试
tests/
test/
coverage/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# 构建产物
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
Makefile
*.o
*.a
*.so
*.dylib
*.dll
*.exe
*.out
*.app

# 数据和日志（不应进入镜像）
data/
logs/
*.log
*.db
*.sqlite3
*.sqlite

# 配置文件中的敏感信息（使用环境变量或 secrets）
.env
.env.local
.env.*.local
config/local.yaml
config/production.yaml
**/secrets.yaml
**/*.key
**/*.pem
**/*.crt (除非是公开证书)

# 文档和示例（减少镜像大小）
docs/
examples/
README.md
CHANGELOG.md
LICENSE
CONTRIBUTING.md

# 临时文件
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
.DS_Store
Thumbs.db

# 调试文件
core
core.*
gmon.out
*.prof

# 大型依赖缓存
.cache/
.parcel-cache/
.next/
.out

# Docker 自身（避免嵌套）
docker-compose.override.yml
docker-compose.*.yml.local

# 监控和调试工具
*.perf
*.trace
