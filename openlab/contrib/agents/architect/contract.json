{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "contract_version": "1.0.0",
  "agent_id": "architect",
  "agent_name": "Architect Agent",
  "description": "系统架构设计与评审智能体，负责架构设计、技术选型建议和架构评审",
  "version": "1.0.0.9",
  "author": "SPHARX Team",
  "license": "Apache-2.0",
  
  "capabilities": [
    {
      "name": "architecture_design",
      "description": "系统架构设计能力",
      "input_schema": {
        "type": "object",
        "properties": {
          "task_type": {
            "type": "string",
            "enum": ["design", "review", "tech_selection"],
            "description": "任务类型"
          },
          "requirements": {
            "type": "object",
            "properties": {
              "scale": {
                "type": "string",
                "enum": ["small", "medium", "large"],
                "description": "系统规模"
              },
              "features": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "所需功能列表"
              },
              "performance": {
                "type": "string",
                "enum": ["low", "medium", "high"],
                "description": "性能要求"
              }
            },
            "required": ["scale", "features"]
          },
          "constraints": {
            "type": "object",
            "description": "约束条件"
          }
        },
        "required": ["task_type", "requirements"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "执行是否成功"
          },
          "output": {
            "type": "object",
            "description": "执行结果"
          },
          "error": {
            "type": "string",
            "description": "错误信息"
          },
          "metrics": {
            "type": "object",
            "description": "执行指标"
          }
        },
        "required": ["success"]
      }
    },
    {
      "name": "documentation",
      "description": "文档生成能力"
    },
    {
      "name": "optimization",
      "description": "架构优化能力"
    }
  ],
  
  "performance": {
    "response_time": {
      "p50": 500,
      "p95": 2000,
      "p99": 5000,
      "unit": "ms"
    },
    "throughput": {
      "min": 10,
      "target": 100,
      "max": 1000,
      "unit": "requests_per_minute"
    },
    "availability": {
      "target": 0.99,
      "min": 0.95
    }
  },
  
  "resources": {
    "cpu": {
      "min": 0.5,
      "max": 4.0,
      "unit": "cores"
    },
    "memory": {
      "min": 512,
      "max": 4096,
      "unit": "MB"
    },
    "storage": {
      "min": 100,
      "max": 10240,
      "unit": "MB"
    }
  },
  
  "dependencies": [
    {
      "name": "openlab.core.agent",
      "version": ">=1.0.0",
      "required": true
    },
    {
      "name": "logging",
      "version": ">=3.10",
      "required": true
    }
  ],
  
  "security": {
    "authentication": "required",
    "authorization": "RBAC",
    "encryption": "TLS_1_3",
    "audit": true,
    "data_classification": "internal"
  },
  
  "monitoring": {
    "metrics": [
      "execution_time",
      "success_rate",
      "error_rate",
      "resource_usage"
    ],
    "logging": {
      "level": "INFO",
      "format": "json",
      "retention_days": 30
    },
    "alerting": {
      "enabled": true,
      "channels": ["email", "slack"]
    }
  },
  
  "lifecycle": {
    "initialization_timeout": 30,
    "shutdown_timeout": 10,
    "health_check_interval": 60,
    "max_retries": 3
  },
  
  "examples": [
    {
      "name": "架构设计示例",
      "input": {
        "task_type": "design",
        "requirements": {
          "scale": "medium",
          "features": ["api", "data_processing"],
          "performance": "high"
        }
      },
      "expected_output": {
        "success": true,
        "output": {
          "architecture_type": "modular_monolith",
          "components": [],
          "tech_stack": {}
        }
      }
    },
    {
      "name": "架构评审示例",
      "input": {
        "task_type": "review",
        "architecture": {
          "type": "microservices",
          "components": []
        }
      },
      "expected_output": {
        "success": true,
        "output": {
          "overall_score": 0.85,
          "strengths": [],
          "weaknesses": []
        }
      }
    }
  ],
  
  "metadata": {
    "created_at": "2026-04-07T00:00:00Z",
    "updated_at": "2026-04-07T00:00:00Z",
    "tags": ["architecture", "design", "review", "tech-selection"],
    "category": "software_engineering",
    "maturity": "production"
  }
}
