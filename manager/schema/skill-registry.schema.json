{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentos.spharx.ai/schemas/skills-registry-v1.schema.json",
  "title": "AgentOS Skills Registry Schema",
  "description": "Configuration schema for Skill registration and metadata",
  "type": "object",
  "required": ["_config_version", "skills"],
  "properties": {
    "_config_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Configuration file version"
    },
    "_metadata": {
      "type": "object",
      "properties": {
        "last_updated": {
          "type": "string",
          "format": "date-time"
        },
        "total_skills": {
          "type": "integer"
        }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["skill_id", "name", "version", "source", "enabled", "unit_type"],
        "properties": {
          "skill_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*_skill$",
            "description": "Unique skill identifier"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Human-readable skill name"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "description": "Skill description"
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Skill version"
          },
          "source": {
            "type": "string",
            "enum": ["builtin", "community", "custom", "external"],
            "description": "Skill source type"
          },
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Whether skill is enabled"
          },
          "unit_type": {
            "type": "string",
            "enum": ["tool", "file", "api", "browser", "db", "code", "shell", "custom"],
            "description": "Execution unit type"
          },
          "contract_path": {
            "type": "string",
            "description": "Path to skill contract file"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Required permissions"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["skill_id"],
              "properties": {
                "skill_id": {
                  "type": "string",
                  "description": "Dependency skill ID"
                },
                "version": {
                  "type": "string",
                  "description": "Version constraint (e.g., >=1.0.0)"
                },
                "optional": {
                  "type": "boolean",
                  "default": false,
                  "description": "Whether dependency is optional"
                }
              }
            },
            "description": "Skill dependencies"
          },
          "compatibility": {
            "type": "object",
            "properties": {
              "min_agentos_version": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              },
              "max_agentos_version": {
                "type": "string",
                "pattern": "^\\d+\\.\\d+\\.\\d+$"
              },
              "platforms": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["linux", "macos", "windows", "all"]
                }
              }
            },
            "description": "Compatibility constraints"
          },
          "resource_limits": {
            "type": "object",
            "properties": {
              "max_memory_mb": {
                "type": "integer",
                "minimum": 64
              },
              "timeout_sec": {
                "type": "integer",
                "minimum": 1,
                "maximum": 86400
              },
              "max_file_size_mb": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "rate_limit": {
            "type": "object",
            "properties": {
              "max_calls_per_minute": {
                "type": "integer",
                "minimum": 1
              },
              "max_calls_per_hour": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for categorization"
          },
          "author": {
            "type": "string",
            "description": "Skill author"
          },
          "license": {
            "type": "string",
            "description": "License identifier"
          },
          "homepage": {
            "type": "string",
            "format": "uri",
            "description": "Skill homepage URL"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
