# =============================================================================
# 16. 必须保留的例外
# =============================================================================

# 以下文件虽然符合上述模式，但必须保留
!.gitignore
!.gitattributes
!.editorconfig
!.pre-commit-manager.yaml
!.clang-format
!.clang-tidy
!.lizardrc
!.jscpd.json
!.semgrep.yml

# 配置文件模板
!.env.example
!manager/*.yaml
!manager/*.yml
!manager/*.template
!manager/*.schema.json

# 关键文档
!manuals/**/*.md
!README.md
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md
!AUTHORS.md
!SECURITY.md
!SUPPORT.md
!CODE_OF_CONDUCT.md
!NOTICE
!ACKNOWLEDGMENTS.md

# 构建脚本（注意：scripts/build/ 和 scripts/deploy/ 是脚本目录）
!scripts/**/*.sh
!scripts/**/*.py
!scripts/**/*.bat
!scripts/**/*.ps1
!scripts/**/*.yml
!scripts/**/*.yaml

# 测试框架
!tests/**/*.py
!tests/**/*.sh
!tests/**/*.yaml
!tests/**/*.yml
!tests/**/*.c
!tests/**/*.h

# Docker 配置
!Dockerfile*
!docker-compose*.yml
!deploy/docker/Dockerfile*

# 根目录脚本
!quickstart.sh
!validate.sh
!Makefile
!pyproject.toml

