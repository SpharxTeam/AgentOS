# =============================================================================
# 16. 必须保留的例外
# =============================================================================

# 以下文件虽然符合上述模式，但必须保留
!.gitignore
!.gitattributes
!.editorconfig
!.pre-commit-config.yaml
!.clang-format
!.clang-tidy
!.semgrep.yml

# 配置文件模板
!.env.example
!config/*.yaml
!config/*.yml
!config/*.template
!config/*.schema.json

# 关键文档
!partdocs/**/*.md
!README.md
!LICENSE
!CHANGELOG.md
!CONTRIBUTING.md
!AUTHORS.md
!SECURITY.md

# 构建脚本
!scripts/**/*.sh
!scripts/**/*.py
!scripts/**/*.bat
!scripts/**/*.ps1

# 测试框架
!tests/**/*.py
!tests/**/*.sh
!tests/**/*.yaml
!tests/**/*.yml

# CI/CD 配置
!.github/workflows/*.yml
!.gitee/workflows/*.yml

# Docker 配置
!Dockerfile*
!docker-compose*.yml
!deploy/docker/Dockerfile*

# =============================================================================
# 结束
